# Copy to .env and fill in real values. Never commit .env.

# Database
POSTGRES_URI=postgresql://user:password@host:5432/dbname

# Auth
JWT_SECRET_KEY=change-me-to-a-long-random-string

# Email verification (optional).
# If no mail settings are present, verification codes are printed to the
# server console instead of being emailed — useful for local development.

# Option 1: Gmail. GMAIL_APP_PASSWORD must be an App Password
# (Google Account > Security > 2-Step Verification > App passwords),
# not the account password.
GMAIL_USER=your-address@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Option 2: any other SMTP provider (used only if the Gmail vars above are unset)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-address@example.com
# SMTP_PASS=your-password

# Display name on the verification email (optional)
SMTP_FROM="Forensic Medical Department" <your-address@gmail.com>
